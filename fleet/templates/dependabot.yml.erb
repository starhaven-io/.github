version: 2
updates:
<% dependabot_entries.each_with_index do |entry, index| -%>
  - package-ecosystem: <%= scalar(entry.fetch("package-ecosystem")) %>
<% if entry.key?("directory") -%>
    directory: <%= scalar(entry.fetch("directory")) %>
<% elsif entry.key?("directories") -%>
    directories:
<% entry.fetch("directories").each do |directory| -%>
      - <%= scalar(directory) %>
<% end -%>
<% end -%>
<% if entry["allow"] -%>
    allow:
<% entry.fetch("allow").each do |allow| -%>
      - dependency-type: <%= scalar(allow.fetch("dependency-type")) %>
<% end -%>
<% end -%>
    schedule:
      interval: "daily"
    cooldown:
      default-days: 7
<% if entry.fetch("package-ecosystem") == "github-actions" -%>
      exclude:
        - "starhaven-io/*"
<% end -%>
<% if entry.fetch("package-ecosystem") == "github-actions" || entry["ignore"] -%>
    ignore:
<% if entry.fetch("package-ecosystem") == "github-actions" -%>
      # Fleet pins are owned by the sync; Dependabot never writes them.
      - dependency-name: "starhaven-io/.github/*"
<% end -%>
<% entry.fetch("ignore", []).each do |ignore| -%>
<% if ignore["reason"] -%>
      # <%= ignore.fetch("reason") %>
<% end -%>
      - dependency-name: <%= scalar(ignore.fetch("dependency-name")) %>
<% if ignore["versions"] -%>
        versions:
<% ignore.fetch("versions").each do |version| -%>
          - <%= scalar(version) %>
<% end -%>
<% end -%>
<% if ignore["update-types"] -%>
        update-types:
<% ignore.fetch("update-types").each do |update_type| -%>
          - <%= scalar(update_type) %>
<% end -%>
<% end -%>
<% end -%>
<% end -%>
    groups:
      <%= scalar(entry.fetch("group")) %>:
        patterns:
          - "*"
<% end -%>
