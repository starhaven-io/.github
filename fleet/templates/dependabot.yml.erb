version: 2
updates:
<% dependabot_entries.each_with_index do |entry, index| -%>
  - package-ecosystem: "<%= entry.fetch("package-ecosystem") %>"
<% if entry.key?("directory") -%>
    directory: "<%= entry.fetch("directory") %>"
<% elsif entry.key?("directories") -%>
    directories:
<% entry.fetch("directories").each do |directory| -%>
      - "<%= directory %>"
<% end -%>
<% end -%>
<% if entry["allow"] -%>
    allow:
<% entry.fetch("allow").each do |allow| -%>
      - dependency-type: "<%= allow.fetch("dependency-type") %>"
<% end -%>
<% end -%>
    schedule:
      interval: "daily"
    cooldown:
      default-days: 7
<% if entry.fetch("package-ecosystem") == "github-actions" -%>
      exclude:
        - "starhaven-io/*"
<% end -%>
<% if entry.fetch("package-ecosystem") == "github-actions" -%>
    ignore:
      # Fleet pins are owned by the sync; Dependabot never writes them.
      - dependency-name: "starhaven-io/.github/*"
<% end -%>
    groups:
      <%= entry.fetch("group") %>:
        patterns:
          - "*"
<% end -%>
