name: zizmor

on:
  push:
    branches:
      - main
    paths:
      - ".github/workflows/**"
<% push_paths.each do |path| -%>
      - <%= scalar(path) %>
<% end -%>
<% if schedule -%>
  schedule:
    - cron: <%= scalar(schedule) %>
  workflow_dispatch:
<% end -%>

concurrency:
  group: "zizmor-${{ github.ref }}"
  cancel-in-progress: false

permissions: {}

jobs:
  zizmor:
    name: Analyze
    permissions:
      contents: read
      security-events: write # required to upload SARIF results
    uses: starhaven-io/.github/.github/workflows/reusable-zizmor.yml@<%= reusable_ref %> # <%= reusable_version %>
<% if timeout_minutes != 15 -%>
    with:
      timeout-minutes: <%= timeout_minutes %>
<% end -%>
